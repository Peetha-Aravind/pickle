<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Landing Page Settings - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Added SortableJS for smooth drag-and-drop -->
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <style>
        body { background-color: #fffbeb; font-family: sans-serif; }
        .glass-panel { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
        .drag-handle { cursor: grab; }
        .drag-handle:active { cursor: grabbing; }
        /* Styling for the item being dragged */
        .sortable-ghost { opacity: 0.4; background-color: #fef3c7; } 
    </style>
</head>
<body class="text-gray-800 min-h-screen pb-20">
    <nav class="glass-panel sticky top-0 z-50 shadow-sm border-b border-amber-200">
        <div class="max-w-7xl mx-auto px-4 flex justify-between h-16 items-center">
            <a href="index.html" class="font-bold text-xl text-amber-900"><i class="fas fa-pepper-hot text-red-600 mr-2"></i>Spicy Delights Admin</a>
            <a href="index.html" class="text-sm font-medium text-gray-600 hover:text-gray-900">Back to Dashboard</a>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-4 py-8 space-y-10">
        
        <div class="flex justify-between items-center border-b border-amber-200 pb-4">
            <div>
                <h2 class="text-3xl font-bold"><i class="fas fa-home mr-2 text-amber-600"></i>Landing Page Setup</h2>
                <p class="text-gray-600 mt-1">Control exactly what customers see on the homepage.</p>
            </div>
            <button onclick="app.saveLandingPage()" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-lg font-bold shadow-lg transition-transform transform hover:scale-105">
                <i class="fas fa-save mr-2"></i>Save Changes
            </button>
        </div>

        <!-- Section 1: Best 6 Pickles -->
        <section class="bg-white rounded-xl shadow p-6 border border-gray-100">
            <div class="mb-6 flex flex-col sm:flex-row justify-between sm:items-end gap-4">
                <div>
                    <h3 class="text-xl font-bold text-gray-800">1. Best Pickles Section</h3>
                    <p class="text-sm text-gray-500">Select and drag to arrange up to 6 products.</p>
                </div>
                <div class="flex items-center space-x-2">
                    <select id="pickle-select" class="px-3 py-2 border rounded-lg bg-gray-50 min-w-[200px] flex-grow">
                        <option value="">Select a pickle...</option>
                    </select>
                    <button onclick="app.addBestPickle()" class="bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-lg font-medium">Add</button>
                </div>
            </div>
            
            <div id="best-pickles-container" class="space-y-3 min-h-[50px]">
                <!-- Best pickles rendered here -->
            </div>
            <p id="best-pickles-empty" class="text-center text-gray-400 py-4 hidden">No pickles added yet.</p>
        </section>

        <!-- Section 2: Categories Setup -->
        <section class="bg-white rounded-xl shadow p-6 border border-gray-100">
            <div class="mb-6">
                <h3 class="text-xl font-bold text-gray-800">2. Homepage Categories</h3>
                <p class="text-sm text-gray-500">Drag by the handle (<i class="fas fa-grip-vertical mx-1"></i>) to rearrange. Toggle to hide from landing page.</p>
            </div>
            
            <!-- Changed from grid layout to full-width list (space-y-3) to increase length -->
            <div id="categories-container" class="space-y-3">
                <!-- Categories rendered here -->
            </div>
        </section>

    </main>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getFirestore, collection, doc, getDoc, getDocs, setDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        const firebaseConfig = { apiKey: "AIzaSyCxjDuFS_ntaOF-K8hFBaxQ0_8CR9yvbkM", authDomain: "pickle-fdc54.firebaseapp.com", projectId: "pickle-fdc54" };
        const db = getFirestore(initializeApp(firebaseConfig));

        window.app = {
            allProducts: [],
            allCategories: [],
            bestPickles: [],   
            landingCategories: [], 
            
            init: async () => {
                const [prodSnap, catSnap, configSnap] = await Promise.all([
                    getDocs(collection(db, 'products')),
                    getDocs(collection(db, 'categories')),
                    getDoc(doc(db, 'landing_page', 'config'))
                ]);

                app.allProducts = prodSnap.docs.map(d => ({ id: d.id, ...d.data() }));
                app.allCategories = catSnap.docs.map(d => ({ id: d.id, ...d.data() }));
                
                const configData = configSnap.exists() ? configSnap.data() : { bestPickles: [], categories: [] };
                app.bestPickles = configData.bestPickles || [];

                const savedCats = configData.categories || [];
                const mergedCats = [];
                
                savedCats.forEach(sc => {
                    if (app.allCategories.some(c => c.id === sc.id)) {
                        mergedCats.push(sc);
                    }
                });

                app.allCategories.forEach(dbCat => {
                    if (!mergedCats.some(mc => mc.id === dbCat.id)) {
                        mergedCats.push({ id: dbCat.id, isVisible: true });
                    }
                });
                app.landingCategories = mergedCats;

                app.render();
                app.initDragAndDrop();
            },

            initDragAndDrop: () => {
                // Initialize drag and drop for Best Pickles
                Sortable.create(document.getElementById('best-pickles-container'), {
                    animation: 150,
                    handle: '.drag-handle', // Only drag by the icon
                    onEnd: function (evt) {
                        // Reconstruct array based on new DOM order
                        const newOrder = Array.from(evt.to.children).map(el => el.dataset.id);
                        app.bestPickles = newOrder;
                        app.renderBestPickles(); // Re-render to update the 1, 2, 3 numbering
                    }
                });

                // Initialize drag and drop for Categories
                Sortable.create(document.getElementById('categories-container'), {
                    animation: 150,
                    handle: '.drag-handle',
                    onEnd: function (evt) {
                        const newOrderIds = Array.from(evt.to.children).map(el => el.dataset.id);
                        // Map the old state to the new order
                        app.landingCategories = newOrderIds.map(id => app.landingCategories.find(c => c.id === id));
                    }
                });
            },

            render: () => {
                app.renderPickleDropdown();
                app.renderBestPickles();
                app.renderCategories();
            },

            renderPickleDropdown: () => {
                const select = document.getElementById('pickle-select');
                const available = app.allProducts.filter(p => !app.bestPickles.includes(p.id));
                
                select.innerHTML = `<option value="">Select a pickle...</option>` + 
                    available.map(p => `<option value="${p.id}">${p.name}</option>`).join('');
                
                select.disabled = app.bestPickles.length >= 6;
                if(app.bestPickles.length >= 6) select.innerHTML = `<option value="">Max 6 selected</option>`;
            },
            
            renderBestPickles: () => {
                const container = document.getElementById('best-pickles-container');
                const emptyMsg = document.getElementById('best-pickles-empty');
                
                if (app.bestPickles.length === 0) {
                    container.innerHTML = '';
                    emptyMsg.classList.remove('hidden');
                    return;
                }
                
                emptyMsg.classList.add('hidden');
                container.innerHTML = app.bestPickles.map((prodId, index) => {
                    const prod = app.allProducts.find(p => p.id === prodId);
                    if(!prod) return '';

                    return `
                        <div data-id="${prodId}" class="flex items-center justify-between bg-white border border-gray-200 rounded-xl p-4 shadow-sm hover:shadow transition-shadow">
                            <div class="flex items-center space-x-4">
                                <i class="fas fa-grip-vertical text-gray-400 text-xl px-2 drag-handle hover:text-amber-600 transition-colors"></i>
                                <span class="text-gray-400 font-bold w-4 text-lg">${index + 1}.</span>
                                <img src="${prod.image}" class="w-14 h-14 rounded-lg object-cover shadow-sm">
                                <span class="font-bold text-lg text-gray-800">${prod.name}</span>
                            </div>
                            <button onclick="app.removePickle(${index})" class="p-3 text-red-500 hover:bg-red-50 rounded-lg transition-colors" title="Remove">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>`;
                }).join('');
            },

            addBestPickle: () => {
                const select = document.getElementById('pickle-select');
                if (!select.value) return;
                if (app.bestPickles.length >= 6) return alert("Maximum 6 pickles allowed.");
                
                app.bestPickles.push(select.value);
                app.renderPickleDropdown();
                app.renderBestPickles();
            },

            removePickle: (index) => {
                app.bestPickles.splice(index, 1);
                app.renderPickleDropdown();
                app.renderBestPickles();
            },

            renderCategories: () => {
                const container = document.getElementById('categories-container');
                
                container.innerHTML = app.landingCategories.map((catConfig, index) => {
                    const dbCat = app.allCategories.find(c => c.id === catConfig.id);
                    if(!dbCat) return '';

                    return `
                        <div data-id="${catConfig.id}" class="flex items-center justify-between bg-white border border-gray-200 rounded-xl p-4 shadow-sm hover:shadow transition-shadow ${!catConfig.isVisible ? 'bg-gray-50 opacity-75' : ''}">
                            <div class="flex items-center space-x-4">
                                <i class="fas fa-grip-vertical text-gray-400 text-xl px-2 drag-handle hover:text-amber-600 transition-colors"></i>
                                <img src="${dbCat.image}" class="w-16 h-16 rounded-lg object-cover shadow-sm">
                                <div>
                                    <p class="font-bold text-lg text-gray-800">${dbCat.name}</p>
                                    <span class="text-sm font-medium ${catConfig.isVisible ? 'text-green-600' : 'text-gray-500'}">
                                        <i class="fas ${catConfig.isVisible ? 'fa-eye' : 'fa-eye-slash'} mr-1"></i>
                                        ${catConfig.isVisible ? 'Visible' : 'Hidden'}
                                    </span>
                                </div>
                            </div>
                            
                            <label class="relative inline-flex items-center cursor-pointer ml-4">
                                <input type="checkbox" class="sr-only peer" ${catConfig.isVisible ? 'checked' : ''} 
                                    onchange="app.toggleCategory(${index})">
                                <div class="w-11 h-6 bg-gray-200 rounded-full peer peer-focus:ring-2 peer-focus:ring-amber-300 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600"></div>
                            </label>
                        </div>`;
                }).join('');
            },

            toggleCategory: (index) => {
                app.landingCategories[index].isVisible = !app.landingCategories[index].isVisible;
                app.renderCategories();
            },

            saveLandingPage: async () => {
                try {
                    const saveBtn = document.querySelector('button[onclick="app.saveLandingPage()"]');
                    saveBtn.innerHTML = `<i class="fas fa-spinner fa-spin mr-2"></i>Saving...`;
                    
                    await setDoc(doc(db, 'landing_page', 'config'), {
                        bestPickles: app.bestPickles,
                        categories: app.landingCategories,
                        updatedAt: Date.now()
                    });
                    
                    saveBtn.innerHTML = `<i class="fas fa-check mr-2"></i>Saved!`;
                    saveBtn.classList.replace('bg-green-600', 'bg-blue-600');
                    
                    setTimeout(() => {
                        saveBtn.innerHTML = `<i class="fas fa-save mr-2"></i>Save Changes`;
                        saveBtn.classList.replace('bg-blue-600', 'bg-green-600');
                    }, 2000);
                    
                } catch (error) {
                    console.error("Error saving: ", error);
                    alert("Error saving layout. Check console.");
                }
            }
        };

        app.init();
    </script>
</body>
</html>
