<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Landing Page - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body { background-color: #fffbeb; font-family: sans-serif; }
        .glass-panel { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
    </style>
</head>
<body class="text-gray-800 min-h-screen pb-24">
    <nav class="glass-panel sticky top-0 z-50 shadow-sm border-b border-amber-200">
        <div class="max-w-7xl mx-auto px-4 flex justify-between h-16 items-center">
            <a href="index.html" class="font-bold text-xl text-amber-900"><i class="fas fa-home text-red-600 mr-2"></i>Landing Page Editor</a>
            <a href="manage-categories.html" class="text-sm font-medium text-gray-600 hover:text-gray-900">Manage Categories</a>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4 py-8 space-y-10">
        
        <!-- SECTION 1: Best 6 Products -->
        <section class="bg-white rounded-xl shadow p-6 border border-amber-100">
            <div class="flex justify-between items-center mb-6 border-b pb-3">
                <h2 class="text-2xl font-bold text-amber-800"><i class="fas fa-star text-yellow-500 mr-2"></i>Best 6 Pickles</h2>
                <span id="product-count" class="text-sm font-bold bg-amber-100 text-amber-800 px-3 py-1 rounded-full">0 / 6 Selected</span>
            </div>

            <div class="flex gap-2 mb-6">
                <select id="product-select" class="flex-1 px-4 py-2 border rounded-lg bg-gray-50 focus:ring-2 focus:ring-amber-300 outline-none">
                    <option value="">-- Select a product to add --</option>
                </select>
                <button onclick="app.addProduct()" class="bg-amber-600 hover:bg-amber-700 text-white px-6 py-2 rounded-lg font-medium shadow transition-colors">
                    Add
                </button>
            </div>

            <div id="best-products-container" class="space-y-3">
                <!-- Product list will be injected here -->
            </div>
        </section>

        <!-- SECTION 2: Category Order & Visibility -->
        <section class="bg-white rounded-xl shadow p-6 border border-amber-100">
            <div class="mb-6 border-b pb-3">
                <h2 class="text-2xl font-bold text-amber-800"><i class="fas fa-layer-group text-blue-500 mr-2"></i>Landing Page Categories</h2>
                <p class="text-sm text-gray-500 mt-1">Reorder categories and toggle their visibility on the main store page.</p>
            </div>

            <div id="landing-categories-container" class="space-y-3">
                <!-- Categories list will be injected here -->
            </div>
        </section>
    </main>

    <!-- Save Bar -->
    <div class="fixed bottom-0 left-0 right-0 glass-panel border-t border-amber-200 p-4 z-40 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <span class="text-gray-600 text-sm font-medium">Don't forget to save your layout changes.</span>
            <button onclick="app.saveLandingPage()" class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-xl font-bold shadow-lg text-lg transition-transform hover:scale-105">
                <i class="fas fa-save mr-2"></i> Save Landing Page
            </button>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getFirestore, collection, doc, getDoc, getDocs, setDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        const firebaseConfig = { apiKey: "AIzaSyCxjDuFS_ntaOF-K8hFBaxQ0_8CR9yvbkM", authDomain: "pickle-fdc54.firebaseapp.com", projectId: "pickle-fdc54" };
        const db = getFirestore(initializeApp(firebaseConfig));

        window.app = {
            allProducts: [],
            selectedProductIds: [], // Stores just the IDs for the top 6
            landingCats: [], // Stores ordered categories with their visibility status

            init: async () => {
                // 1. Fetch all products
                const prodSnap = await getDocs(collection(db, 'products'));
                app.allProducts = prodSnap.docs.map(d => ({ id: d.id, ...d.data() }));

                // 2. Fetch all categories
                const catSnap = await getDocs(collection(db, 'categories'));
                const dbCats = catSnap.docs.map(d => ({ id: d.id, ...d.data() }));

                // 3. Fetch existing landing page config
                const landingDoc = await getDoc(doc(db, 'landingpage', 'newdocument'));
                let savedCats = [];
                
                if (landingDoc.exists()) {
                    const data = landingDoc.data();
                    app.selectedProductIds = data.bestProducts || [];
                    savedCats = data.landingCategories || [];
                }

                // 4. Merge DB Categories with Saved Landing Page order/visibility
                app.landingCats = [];
                // First, add saved categories in their saved order
                savedCats.forEach(sc => {
                    const found = dbCats.find(c => c.id === sc.id);
                    if (found) app.landingCats.push({ ...found, isVisibleOnLanding: sc.visible });
                });
                // Next, append any new categories that haven't been added to the landing page config yet
                dbCats.forEach(c => {
                    if (!savedCats.find(sc => sc.id === c.id)) {
                        app.landingCats.push({ ...c, isVisibleOnLanding: true }); // Default to true for new ones
                    }
                });

                app.renderProductDropdown();
                app.renderBestProducts();
                app.renderCategories();
            },

            // --- BEST PRODUCTS LOGIC ---

            renderProductDropdown: () => {
                const select = document.getElementById('product-select');
                select.innerHTML = '<option value="">-- Select a product to add --</option>';
                app.allProducts.forEach(p => {
                    // Only show products not already selected
                    if (!app.selectedProductIds.includes(p.id)) {
                        select.innerHTML += `<option value="${p.id}">${p.name} (₹${p.price})</option>`;
                    }
                });
            },

            renderBestProducts: () => {
                document.getElementById('product-count').innerText = `${app.selectedProductIds.length} / 6 Selected`;
                const container = document.getElementById('best-products-container');
                
                if (app.selectedProductIds.length === 0) {
                    container.innerHTML = `<div class="text-center p-6 text-gray-400 border-2 border-dashed rounded-xl">No products selected yet.</div>`;
                    return;
                }

                container.innerHTML = app.selectedProductIds.map((id, index) => {
                    const prod = app.allProducts.find(p => p.id === id);
                    if(!prod) return ''; // Fallback if product was deleted from DB

                    return `
                        <div class="flex items-center justify-between p-3 bg-gray-50 border rounded-lg shadow-sm">
                            <div class="flex items-center space-x-4">
                                <span class="font-bold text-gray-400 w-6">${index + 1}.</span>
                                <img src="${prod.image}" class="w-12 h-12 rounded object-cover">
                                <span class="font-bold">${prod.name}</span>
                            </div>
                            <div class="flex space-x-2">
                                <button onclick="app.moveProduct(${index}, -1)" class="p-2 text-gray-500 hover:text-amber-600 disabled:opacity-30" ${index === 0 ? 'disabled' : ''}><i class="fas fa-arrow-up"></i></button>
                                <button onclick="app.moveProduct(${index}, 1)" class="p-2 text-gray-500 hover:text-amber-600 disabled:opacity-30" ${index === app.selectedProductIds.length - 1 ? 'disabled' : ''}><i class="fas fa-arrow-down"></i></button>
                                <button onclick="app.removeProduct('${id}')" class="p-2 text-red-500 hover:text-red-700 ml-2"><i class="fas fa-times"></i></button>
                            </div>
                        </div>
                    `;
                }).join('');
            },

            addProduct: () => {
                const select = document.getElementById('product-select');
                const id = select.value;
                if (!id) return alert("Please select a product first.");
                if (app.selectedProductIds.length >= 6) return alert("You can only select up to 6 products.");
                
                app.selectedProductIds.push(id);
                app.renderProductDropdown();
                app.renderBestProducts();
            },

            removeProduct: (id) => {
                app.selectedProductIds = app.selectedProductIds.filter(pid => pid !== id);
                app.renderProductDropdown();
                app.renderBestProducts();
            },

            moveProduct: (index, direction) => {
                const newIndex = index + direction;
                if (newIndex < 0 || newIndex >= app.selectedProductIds.length) return;
                
                // Swap elements
                const temp = app.selectedProductIds[index];
                app.selectedProductIds[index] = app.selectedProductIds[newIndex];
                app.selectedProductIds[newIndex] = temp;
                
                app.renderBestProducts();
            },

            // --- CATEGORIES LOGIC ---

            renderCategories: () => {
                const container = document.getElementById('landing-categories-container');
                if (app.landingCats.length === 0) {
                    container.innerHTML = `<p class="text-gray-500">No categories found in store.</p>`;
                    return;
                }

                container.innerHTML = app.landingCats.map((cat, index) => {
                    const isVisible = cat.isVisibleOnLanding;
                    return `
                        <div class="flex items-center justify-between p-3 bg-gray-50 border rounded-lg shadow-sm ${!isVisible ? 'opacity-60' : ''}">
                            <div class="flex items-center space-x-4 flex-1">
                                <span class="font-bold text-gray-400 w-6">${index + 1}.</span>
                                <img src="${cat.image}" class="w-12 h-12 rounded object-cover grayscale-${!isVisible ? '100' : '0'}">
                                <div>
                                    <h3 class="font-bold ${!isVisible ? 'line-through text-gray-500' : 'text-gray-800'}">${cat.name}</h3>
                                    <span class="text-xs font-medium ${isVisible ? 'text-green-600' : 'text-red-500'}">${isVisible ? 'Visible on Landing' : 'Hidden on Landing'}</span>
                                </div>
                            </div>
                            
                            <div class="flex items-center space-x-6">
                                <!-- Visibility Toggle -->
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" class="sr-only peer" ${isVisible ? 'checked' : ''} onchange="app.toggleCategory(${index})">
                                    <div class="w-11 h-6 bg-gray-300 rounded-full peer peer-focus:ring-2 peer-focus:ring-amber-300 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600"></div>
                                </label>

                                <!-- Reorder Buttons -->
                                <div class="flex space-x-1 border-l pl-4">
                                    <button onclick="app.moveCategory(${index}, -1)" class="p-2 text-gray-500 hover:text-amber-600 disabled:opacity-30" ${index === 0 ? 'disabled' : ''}><i class="fas fa-arrow-up"></i></button>
                                    <button onclick="app.moveCategory(${index}, 1)" class="p-2 text-gray-500 hover:text-amber-600 disabled:opacity-30" ${index === app.landingCats.length - 1 ? 'disabled' : ''}><i class="fas fa-arrow-down"></i></button>
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');
            },

            toggleCategory: (index) => {
                app.landingCats[index].isVisibleOnLanding = !app.landingCats[index].isVisibleOnLanding;
                app.renderCategories();
            },

            moveCategory: (index, direction) => {
                const newIndex = index + direction;
                if (newIndex < 0 || newIndex >= app.landingCats.length) return;
                
                // Swap elements
                const temp = app.landingCats[index];
                app.landingCats[index] = app.landingCats[newIndex];
                app.landingCats[newIndex] = temp;
                
                app.renderCategories();
            },

            // --- SAVE LOGIC ---

            saveLandingPage: async () => {
                try {
                    // Format category data to save only the required fields (ID and visibility state) to save bandwidth
                    const categoriesToSave = app.landingCats.map(cat => ({
                        id: cat.id,
                        visible: cat.isVisibleOnLanding
                    }));

                    const data = {
                        bestProducts: app.selectedProductIds,
                        landingCategories: categoriesToSave,
                        lastUpdated: Date.now()
                    };

                    // Write to landingpage > newdocument
                    await setDoc(doc(db, 'landingpage', 'newdocument'), data);
                    
                    alert("Landing page configuration saved successfully!");
                } catch (error) {
                    console.error("Error saving landing page:", error);
                    alert("Failed to save. Check the console for details.");
                }
            }
        };

        app.init();
    </script>
</body>
</html>
